---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allTranslations = await getCollection('translations');
const sorted = allTranslations.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout>
  <div class="container">
    <section class="article-list">
      <div class="article-list-header">
        <span class="list-label">Articles</span>
        <div class="list-rule"></div>
        <span class="count-badge">{sorted.length}</span>
      </div>

      {sorted.length === 0 ? (
        <div class="empty-state">
          <div class="empty-state-icon">—</div>
          <p class="empty-title">暂无译文</p>
          <p class="empty-desc">
            将 Markdown 文件放入 <code>src/content/translations/</code> 目录即可
          </p>
        </div>
      ) : (
        sorted.map((entry) => (
          <article class="article-card">
            <div class="article-card-left">
              <a href={`${baseUrl}translations/${entry.id}/`} class="article-card-title">
                {entry.data.title}
              </a>
              <div class="article-card-meta">
                <span class="article-date">{formatDate(entry.data.date)}</span>
                {entry.data.source && (
                  <span class="article-source">{entry.data.source}</span>
                )}
                {entry.data.originalUrl ? (
                  <a
                    href={entry.data.originalUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn-original"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                      <polyline points="15 3 21 3 21 9"/>
                      <line x1="10" y1="14" x2="21" y2="3"/>
                    </svg>
                    原文
                  </a>
                ) : (
                  <span class="btn-original btn-original-disabled">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                      <polyline points="15 3 原文 3 21 9"/>
                      <line x1="10" y1="14" x2="21" y2="3"/>
                    </svg>
                    原文
                  </span>
                )}
              </div>
            </div>
          </article>
        ))
      )}
    </section>
  </div>
</BaseLayout>
