---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'TranslateLM',
  description = '精选 AI 领域优质文章翻译',
} = Astro.props;

const fullTitle = title === 'TranslateLM' ? title : `${title} — TranslateLM`;
const baseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Noto+Serif+SC:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href={`${baseUrl}global.css`} />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a href={baseUrl} class="site-logo">
          Translate<span>LM</span>
        </a>
        <span class="nav-desc">AI 领域优质文章翻译</span>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer-inner">
        <span class="footer-text">TranslateLM</span>
        <span class="footer-text">
          Translate powered by
          <a
            class="footer-link"
            href="https://github.com/wanggang316/skills/tree/main/article-translate"
            target="_blank"
            rel="noreferrer"
          >
            article-translate
          </a>
          skill.
        </span>
      </div>
    </footer>
  </body>
</html>
